# ===================================================
# КОДИРОВКА (КРИТИЧНО ДЛЯ ВАЛИДАТОРА)
# ===================================================

AddDefaultCharset UTF-8

# ===================================================
# БЕЗОПАСНОСТЬ
# ===================================================

<IfModule mod_headers.c>

    # Принудительная установка charset для HTML
    <FilesMatch "\.(html|htm)$">
        Header set Content-Type "text/html; charset=UTF-8"
    </FilesMatch>

    # Content Security Policy
    Header set Content-Security-Policy "\
        default-src 'self'; \
        upgrade-insecure-requests; \
        frame-ancestors 'self'; \
        script-src 'self' 'unsafe-inline' 'unsafe-eval' \
            https://mc.yandex.ru \
            https://mc.yandex.com \
            https://mc.yandex.by \
            https://www.googletagmanager.com \
            https://www.google-analytics.com \
            https://cdn.jsdelivr.net \
            https://cdn.emailjs.com; \
        style-src 'self' 'unsafe-inline'; \
        img-src 'self' https: data: \
            https://mc.yandex.ru \
            https://mc.yandex.com \
            https://mc.yandex.by; \
        font-src 'self'; \
        connect-src 'self' https: wss: \
            https://api.emailjs.com \
            https://mc.yandex.ru \
            https://mc.yandex.com \
            https://mc.yandex.by \
            wss://mc.yandex.ru \
            wss://mc.yandex.com \
            https://www.google-analytics.com; \
        frame-src 'self' \
            https://yandex.ru \
            https://api-maps.yandex.ru; \
        worker-src 'self' blob:; \
        object-src 'none'; \
        base-uri 'self'; \
        form-action 'self';"

    # Защита от clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"

    # Защита от MIME-type sniffing
    Header always set X-Content-Type-Options "nosniff"

    # XSS Protection
    Header always set X-XSS-Protection "1; mode=block"

    # Referrer Policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Permissions Policy
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"

    # HSTS
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # Кеширование CSS и JS (Astro генерирует файлы с хешем)
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

</IfModule>

# ===================================================
# ЗАЩИТА ОТ ДОСТУПА К СЛУЖЕБНЫМ ФАЙЛАМ
# ===================================================

<FilesMatch "^\.">
    Require all denied
</FilesMatch>

<FilesMatch "\.(sql|log|env|yml|yaml)$">
    Require all denied
</FilesMatch>

# ===================================================
# РЕДИРЕКТЫ И МАРШРУТИЗАЦИЯ
# ===================================================

<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]
</IfModule>

# ===================================================
# ОБРАБОТКА ОШИБОК
# ===================================================

ErrorDocument 404 /404.html

# ===================================================
# СКРЫТЬ ВЕРСИЮ СЕРВЕРА
# ===================================================

ServerSignature Off

# ===================================================
# КЕШИРОВАНИЕ (производительность)
# ===================================================

<IfModule mod_expires.c>
    ExpiresActive On

    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"

    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"

    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# ===================================================
# СЖАТИЕ (производительность)
# ===================================================

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json text/xml application/xml
    AddOutputFilterByType DEFLATE application/font-woff application/font-woff2
</IfModule>