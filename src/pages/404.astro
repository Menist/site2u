---
import Layout from '../layouts/Layout.astro'
---
<Layout title="Страница не найдена | site2u.by"
        description="Запрашиваемая страница не существует. Вернитесь на главную страницу site2u.by">

  <div class="not-found container">
    <div class="not-found__inner">
      <span class="not-found__code">404</span>
      <h1 class="not-found__title">Страница не найдена</h1>
      <p class="not-found__desc">Возможно, страница была удалена или вы перешли по неверной ссылке.</p>
      <div class="not-found__actions">
        <a href="/" class="not-found__btn">На главную</a>
        <a href="/kontakty/" class="not-found__link">Связаться с нами →</a>
      </div>
    </div>
  </div>

</Layout>

<style>
  .not-found {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    padding: var(--space-3xl) 0;
  }

  .not-found__inner {
    text-align: center;
    max-width: 480px;
  }

  .not-found__code {
    display: block;
    font-size: clamp(80px, 15vw, 160px);
    font-weight: var(--font-weight-bold);
    line-height: 1;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
  }

  .not-found__title {
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--space-md);
  }

  .not-found__desc {
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
    margin-bottom: var(--space-xl);
  }

  .not-found__actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }

  .not-found__btn {
    display: inline-block;
    background: var(--color-accent);
    color: var(--color-text-primary);
    font-weight: var(--font-weight-semibold);
    padding: var(--space-sm) var(--space-xl);
    border-radius: var(--radius-full);
    transition: background var(--transition-base), transform var(--transition-base);
  }

  .not-found__btn:hover {
    background: var(--color-accent-hover);
    transform: translateY(-2px);
  }

  .not-found__link {
    color: var(--color-accent-hover);
    font-weight: var(--font-weight-semibold);
    transition: var(--transition-color);
  }

  .not-found__link:hover {
    color: var(--color-text-primary);
  }

  /* ==========================================================================
   АДАПТИВНАЯ ВЕРСТКА: not-found (404)
   ========================================================================== */

  /* ===== Планшеты (до 992px) ===== */
  @media (max-width: 992px) {
    .not-found {
      min-height: 50vh;
      padding: var(--space-2xl) 0;
    }

    .not-found__inner {
      max-width: 420px;
    }

    .not-found__code {
      font-size: clamp(70px, 12vw, 120px);
      margin-bottom: var(--space-sm);
    }

    .not-found__title {
      font-size: var(--font-size-xl);
      margin-bottom: var(--space-sm);
    }

    .not-found__desc {
      font-size: var(--font-size-base);
      margin-bottom: var(--space-lg);
    }

    .not-found__actions {
      gap: var(--space-md);
    }

    .not-found__btn {
      padding: var(--space-sm) var(--space-lg);
      font-size: var(--font-size-base);
    }

    .not-found__link {
      font-size: var(--font-size-base);
    }
  }

  /* ===== Мобильные (до 768px) ===== */
  @media (max-width: 768px) {
    .not-found {
      min-height: 70vh;
      min-height: 70dvh; /* Для мобильных браузеров */
      padding: var(--space-xl) 0;
    }

    .not-found__inner {
      max-width: 100%;
      padding: 0 var(--space-sm);
    }

    .not-found__code {
      font-size: clamp(60px, 15vw, 100px);
      margin-bottom: var(--space-xs);
    }

    .not-found__title {
      font-size: var(--font-size-lg);
      margin-bottom: var(--space-sm);
    }

    .not-found__desc {
      font-size: var(--font-size-sm);
      margin-bottom: var(--space-lg);
      line-height: var(--line-height-relaxed);
      padding: 0 var(--space-xs);
    }

    .not-found__actions {
      flex-direction: column;
      gap: var(--space-sm);
      width: 100%;
      max-width: 320px;
      margin: 0 auto;
    }

    .not-found__btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      padding: var(--space-xs) var(--space-lg);
      font-size: var(--font-size-sm);
      min-height: var(--touch-target-min);
    }

    .not-found__btn:hover {
      transform: none;
    }

    .not-found__link {
      font-size: var(--font-size-sm);
      display: inline-block;
      padding: var(--space-xs) 0;
      min-height: var(--touch-target-min);
      min-width: var(--touch-target-min);
    }

    .not-found__link:hover {
      color: var(--color-accent-hover);
    }
  }

  /* ===== Маленькие телефоны (до 480px) ===== */
  @media (max-width: 480px) {
    .not-found {
      min-height: 80vh;
      min-height: 80dvh;
      padding: var(--space-lg) 0;
    }

    .not-found__inner {
      padding: 0 var(--space-xs);
    }

    .not-found__code {
      font-size: clamp(50px, 12vw, 80px);
      margin-bottom: var(--space-xs);
    }

    .not-found__title {
      font-size: var(--font-size-md);
      margin-bottom: var(--space-xs);
    }

    .not-found__desc {
      font-size: var(--font-size-sm);
      margin-bottom: var(--space-md);
      padding: 0 4px;
    }

    .not-found__actions {
      max-width: 100%;
      gap: var(--space-xs);
    }

    .not-found__btn {
      font-size: var(--font-size-sm);
      padding: var(--space-xs) var(--space-md);
      min-height: var(--touch-target-min);
    }

    .not-found__link {
      font-size: var(--font-size-sm);
      min-height: var(--touch-target-min);
    }
  }

  /* ===== Очень узкие экраны (до 360px) ===== */
  @media (max-width: 360px) {
    .not-found {
      min-height: 85vh;
      min-height: 85dvh;
      padding: var(--space-md) 0;
    }

    .not-found__inner {
      padding: 0 4px;
    }

    .not-found__code {
      font-size: clamp(40px, 10vw, 60px);
      margin-bottom: 4px;
    }

    .not-found__title {
      font-size: var(--font-size-base);
      margin-bottom: 4px;
    }

    .not-found__desc {
      font-size: var(--font-size-xs);
      margin-bottom: var(--space-md);
    }

    .not-found__btn {
      font-size: var(--font-size-xs);
      padding: 6px var(--space-sm);
      min-height: 38px;
    }

    .not-found__link {
      font-size: var(--font-size-xs);
      min-height: 38px;
    }
  }

  /* ==========================================================================
     ДОПОЛНИТЕЛЬНЫЕ УЛУЧШЕНИЯ
     ========================================================================== */

  /* Адаптация для экранов с высотой меньше 700px */
  @media (max-height: 700px) {
    .not-found {
      min-height: 80vh;
      min-height: 80dvh;
      padding: var(--space-lg) 0;
    }

    .not-found__code {
      font-size: clamp(50px, 10vw, 80px);
      margin-bottom: var(--space-xs);
    }

    .not-found__title {
      font-size: var(--font-size-lg);
      margin-bottom: var(--space-xs);
    }

    .not-found__desc {
      font-size: var(--font-size-sm);
      margin-bottom: var(--space-md);
    }

    .not-found__actions {
      gap: var(--space-sm);
    }
  }

  /* Адаптация для экранов с высотой меньше 600px */
  @media (max-height: 600px) {
    .not-found {
      min-height: 90vh;
      min-height: 90dvh;
      padding: var(--space-md) 0;
    }

    .not-found__code {
      font-size: clamp(40px, 8vw, 60px);
      margin-bottom: 4px;
    }

    .not-found__title {
      font-size: var(--font-size-base);
      margin-bottom: 4px;
    }

    .not-found__desc {
      font-size: var(--font-size-xs);
      margin-bottom: var(--space-sm);
    }

    .not-found__btn {
      padding: 6px var(--space-md);
      font-size: var(--font-size-xs);
      min-height: 36px;
    }

    .not-found__link {
      font-size: var(--font-size-xs);
      min-height: 36px;
    }
  }

  /* Отключение hover на touch-устройствах */
  @media (hover: none) {
    .not-found__btn:hover {
      transform: none !important;
    }

    .not-found__link:hover {
      color: var(--color-accent-hover) !important;
    }
  }

  /* Анимация для 404 (опционально) */
  @media (prefers-reduced-motion: no-preference) {
    .not-found__code {
      animation: pulse 2s ease-in-out infinite;
    }

    @keyframes pulse {
      0%, 100% {
        transform: scale(1);
      }
      50% {
        transform: scale(1.02);
      }
    }
  }

  /* Отключаем анимацию для пользователей с reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .not-found__code {
      animation: none;
    }
  }
</style>