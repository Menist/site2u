---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const breadcrumbItems = [
  { label: "Главная", href: "/" },
  { label: "Контакты", href: "/kontakty" },
];

const serviceId = import.meta.env.EMAILJS_SERVICE_ID;
const templateId = import.meta.env.EMAILJS_TEMPLATE_ID;
const publicKey = import.meta.env.EMAILJS_PUBLIC_KEY;
---

<Layout title="Контакты | site2u.by"
        description="Свяжитесь с нами: телефон, email, адрес офиса в Минске. Работаем удалённо по всей Беларуси.">
  <Breadcrumbs items={breadcrumbItems} />

  <section class="contacts section--padded">
    <div class="container">

      <div class="contacts__grid">
        <div class="contacts__left">

          <div class="contacts__info">
            <h2 class="contacts-heading">Свяжитесь с нами</h2>
            <span class="service-detail__rule"></span>

            <div class="contacts__group">
              <a href="tel:+375296195265" class="contacts__link">+375 (29) 619-52-65</a>
              <a href="mailto:hello@site2u.by" class="contacts__link">hello@site2u.by</a>
            </div>

            <p class="contacts__address">Офис в Минске, работаем удалённо по всей Беларуси</p>

            <div class="contacts__socials">
              <a href="#" class="contacts__social">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                  <path d="M21.6 3.8L18.2 20.1C17.9 21.3 17.2 21.6 16.2 21L11.7 17.7L9.5 19.8C9.2 20.1 9 20.4 8.4 20.4L8.7 15.7L17.4 7.8C17.8 7.4 17.5 7.2 17 7.6L6.3 14.3L1.7 12.8C0.7 12.5 0.7 11.8 1.9 11.3L20.1 4.3C21 4 21.8 4.5 21.6 3.8Z" fill="currentColor"/>
                </svg>
                <span>Telegram</span>
              </a>
              <a href="#" class="contacts__social">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                  <path d="M18.9 2.8C16.5 1.2 7.5 1.2 5.1 2.8C2.4 4.7 2.2 8.4 2.5 11.2C2.8 14 4.5 16 6.7 17.3L6.2 21L10 18.8C12.5 19.2 17.8 19 19.2 16.8C20.8 14.2 21.5 4.5 18.9 2.8Z" fill="currentColor"/>
                  <path d="M8 8C9.5 11 11.5 13 15 14" stroke="white" stroke-width="1.8" stroke-linecap="round"/>
                </svg>
                <span>Viber</span>
              </a>
            </div>
          </div>

          <div class="contacts__form-card">
            <h2 class="contacts__form-title">Оставить заявку</h2>

            <form class="contacts__form" id="contactForm" novalidate>
              <input type="hidden" id="cfg-result-hidden" name="cfg_result" value=""/>

              <div class="contacts__field">
                <input type="text" id="form-name" name="from_name"
                       class="contacts__input" placeholder=" " required autocomplete="name"/>
                <label for="form-name">Ваше имя *</label>
              </div>

              <div class="contacts__field">
                <input type="tel" id="form-phone" name="from_phone"
                       class="contacts__input" placeholder=" " required autocomplete="tel"/>
                <label for="form-phone">Телефон *</label>
              </div>

              <div class="contacts__field">
                <textarea id="form-message" name="message"
                          class="contacts__input contacts__textarea" placeholder=" " rows="4"></textarea>
                <label for="form-message">Кратко о проекте</label>
              </div>

              <button type="submit" class="contacts__submit" id="formSubmit">
                Отправить заявку
              </button>

              <p class="contacts__status" id="formStatus" aria-live="polite"></p>
            </form>
          </div>

        </div>
        <div class="contacts__map">
          <div class="contacts__map-overlay">
            <div class="contacts__map-hint">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
                <circle cx="12" cy="9" r="2.5"/>
              </svg>
              <span>г. Минск, пр. Независимости, д. 68-2, к.108</span>
            </div>
          </div>

          <a href="https://yandex.by/maps/?rtext=~53.921621,27.600243&rtt=auto"
             target="_blank" rel="noopener" class="contacts__map-route">
            Построить маршрут
          </a>

          <iframe
              data-src="https://yandex.ru/map-widget/v1/?ll=27.600281%2C53.921440&z=17&pt=27.600243,53.921621,pm2orgm"
              width="100%"
              height="100%"
              frameborder="0"
              allowfullscreen="true"
              loading="lazy"
              class="js-lazy-iframe">
          </iframe>
        </div>

      </div>
    </div>
  </section>
</Layout>

<style>
  .contacts__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
    align-items: start;
    margin: var(--space-lg) 0 var(--space-md);
  }
  .contacts-heading {
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-bold);
  }

  @media (max-width: 900px) {
    .contacts__grid {
      grid-template-columns: 1fr;
    }
  }

  /* Инфо */
  .contacts__info {
    margin-bottom: var(--space-2xl);
  }

  .contacts__group {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin: var(--space-lg) 0;
  }

  .contacts__link {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
    transition: var(--transition-color);
    width: max-content;
  }

  .contacts__link:hover {
    color: var(--color-accent-hover);
  }

  .contacts__address {
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
    margin-bottom: var(--space-lg);
  }

  .contacts__socials {
    display: flex;
    gap: var(--space-sm);
  }

  .contacts__social {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    height: 42px;
    padding: 0 var(--space-md);
    border: 1px solid var(--color-divider);
    border-radius: var(--radius-full);
    color: var(--color-text-primary);
    font-size: var(--font-size-sm);
    transition: border-color var(--transition-base), color var(--transition-base), transform var(--transition-base);
  }

  .contacts__social svg {
    color: var(--color-accent-hover);
    width: 18px;
    height: 18px;
  }

  .contacts__social:hover {
    border-color: var(--color-accent);
    color: var(--color-accent-hover);
    transform: translateY(-2px);
  }

  /* Форма */
  .contacts__form-card {
    background: var(--color-bg-secondary);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
  }

  .contacts__form-title {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--space-lg);
  }

  .contacts__form {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .contacts__field {
    position: relative;
  }

  .contacts__input {
    width: 100%;
    padding: var(--space-sm) var(--space-md);
    border: 1px solid var(--color-divider);
    border-radius: var(--radius-sm);
    background: var(--color-bg-primary);
    color: var(--color-text-primary);
    font-size: var(--font-size-base);
    transition: border-color var(--transition-base), box-shadow var(--transition-base);
  }

  .contacts__input:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(255, 190, 73, 0.15);
  }

  .contacts__input.is-error {
    border-color: #ff7c7c;
  }

  .contacts__field label {
    position: absolute;
    left: var(--space-md);
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    color: var(--color-text-secondary);
    font-size: var(--font-size-sm);
    transition: 0.25s ease;
    background: transparent;
  }

  .contacts__textarea {
    min-height: 120px;
    resize: vertical;
    padding-top: var(--space-sm);
  }

  .contacts__textarea + label {
    top: var(--space-sm);
    transform: none;
  }

  .contacts__input:focus + label,
  .contacts__input:not(:placeholder-shown) + label {
    top: -10px;
    transform: none;
    padding: 0 6px;
    background: var(--color-bg-secondary);
    color: var(--color-accent-hover);
    font-size: var(--font-size-xs);
  }

  .contacts__submit {
    width: 100%;
    padding: var(--space-sm) var(--space-md);
    border: none;
    border-radius: var(--radius-sm);
    background: var(--color-accent);
    color: var(--color-text-primary);
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    cursor: pointer;
    transition: background var(--transition-base), transform var(--transition-base);
  }

  .contacts__submit:hover {
    background: var(--color-accent-hover);
    transform: translateY(-2px);
  }

  .contacts__submit:disabled {
    opacity: 0.6;
    cursor: default;
    transform: none;
  }

  .contacts__status {
    min-height: 24px;
    font-size: var(--font-size-sm);
  }

  .contacts__status.is-success { color: #4caf7d; }
  .contacts__status.is-error { color: #ff7c7c; }

  /* Карта */
  .contacts__map {
    position: relative;
    height: 100%;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-divider);
    //margin: var(--space-lg) 0 var(--space-md);
  }

  .contacts__map iframe {
    width: 100%;
    height: 100%;
    opacity: 0.9;
    transition: opacity var(--transition-base);
  }

  .contacts__map:hover iframe {
    opacity: 1;
  }

  .contacts__map-overlay {
    position: absolute;
    top: 57%;
    left: 50%;
    transform: translate(-50%, -100%);
    z-index: 4;
    transition: opacity var(--transition-base);
  }

  .contacts__map:hover .contacts__map-overlay {
    opacity: 0.2;
  }

  .contacts__map-hint {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-md);
    background: rgba(255, 255, 255, 0.95);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    max-width: 280px;
  }

  .contacts__map-hint svg {
    flex-shrink: 0;
    color: var(--color-accent-hover);
  }

  .contacts__map-hint span {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
    line-height: var(--line-height-normal);
  }

  .contacts__map-route {
    position: absolute;
    bottom: var(--space-xl);
    left: var(--space-xs);
    z-index: 10;
    display: inline-flex;
    align-items: center;
    height: 42px;
    padding: 0 var(--space-md);
    background: rgba(255, 255, 255, 0.95);
    border: 1px solid var(--color-divider);
    border-radius: var(--radius-full);
    color: var(--color-text-primary);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    transition: border-color var(--transition-base), color var(--transition-base);
  }

  .contacts__map-route:hover {
    border-color: var(--color-accent);
    color: var(--color-accent-hover);
  }
</style>

<script define:vars={{ serviceId, templateId, publicKey }}>
  async function initContactForm() {
    if (typeof emailjs === 'undefined') {
      const script = document.createElement('script');
      script.src = 'https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js';
      await new Promise((resolve) => { script.onload = resolve; document.head.appendChild(script); });
    }

    emailjs.init({ publicKey });

    const form = document.getElementById('contactForm');
    if (!form) return;

    const submitBtn = document.getElementById('formSubmit');
    const statusEl = document.getElementById('formStatus');

    function showStatus(text, type = '') {
      statusEl.textContent = text;
      statusEl.className = type ? `contacts__status is-${type}` : 'contacts__status';
    }

    function validate() {
      let valid = true;
      const fields = [form.querySelector('[name="from_name"]'), form.querySelector('[name="from_phone"]')];
      fields.forEach(el => {
        el.classList.remove('is-error');
        if (!el.value.trim()) { el.classList.add('is-error'); valid = false; }
      });
      return valid;
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!validate()) { showStatus('Пожалуйста, заполните обязательные поля.', 'error'); return; }
      submitBtn.disabled = true;
      submitBtn.textContent = 'Отправляем...';
      showStatus('');
      try {
        await emailjs.sendForm(serviceId, templateId, form);
        showStatus('Заявка отправлена! Свяжемся с вами в ближайшее время.', 'success');
        form.reset();
      } catch (err) {
        console.error('EmailJS error:', err);
        showStatus('Ошибка отправки. Напишите напрямую на hello@site2u.by', 'error');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Отправить заявку';
      }
    });

    form.querySelectorAll('.contacts__input').forEach(el => {
      el.addEventListener('input', () => {
        el.classList.remove('is-error');
        if (statusEl.classList.contains('is-error')) showStatus('');
      });
    });

    // Ленивая загрузка карты
    const iframe = document.querySelector('.js-lazy-iframe');
    if (iframe) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            iframe.src = iframe.dataset.src;
            observer.disconnect();
          }
        });
      }, { rootMargin: '200px' });
      observer.observe(iframe);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initContactForm);
  } else {
    initContactForm();
  }
</script>