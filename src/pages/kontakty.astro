<script define:vars={{ serviceId, templateId, publicKey }}>
  async function initContactForm() {
    if (typeof emailjs === 'undefined') {
      const script = document.createElement('script');
      script.src = 'https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js';
      await new Promise((resolve) => { script.onload = resolve; document.head.appendChild(script); });
    }

    emailjs.init({ publicKey });

    const form = document.getElementById('contactForm');
    if (!form) return;

    const submitBtn = document.getElementById('formSubmit');
    const statusEl = document.getElementById('formStatus');

    function showStatus(text, type = '') {
      statusEl.textContent = text;
      statusEl.className = type ? `contacts__status is-${type}` : 'contacts__status';
    }

    // ── УДАЛЕНА СТАРАЯ ВАЛИДАЦИЯ ──
    // Теперь валидация в validation.js

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Если validation.js нашёл ошибки — классы is-error уже расставлены
      const hasErrors = form.querySelectorAll('.is-error').length > 0;
      if (hasErrors) {
        showStatus('Пожалуйста, исправьте ошибки в форме.', 'error');
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'Отправляем...';
      showStatus('');
      try {
        await emailjs.sendForm(serviceId, templateId, form);
        if (typeof gtag !== 'undefined') gtag('event', 'contact_form_submit', { event_category: 'form' });
        if (typeof ym !== 'undefined') ym(110113534, 'reachGoal', 'contact_form_submit');

        showStatus('Заявка отправлена! Свяжемся с вами в ближайшее время.', 'success');
        form.reset();
        // Очищаем классы и ошибки
        form.querySelectorAll('.is-error, .is-valid').forEach(el => el.classList.remove('is-error', 'is-valid'));
        form.querySelectorAll('.field-error, .field-hint').forEach(el => el.remove());
      } catch (err) {
        console.error('EmailJS error:', err);
        showStatus('Ошибка отправки. Напишите напрямую на hello@site2u.by', 'error');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Отправить';
      }
    });

    // Ленивая загрузка карты
    const iframe = document.querySelector('.js-lazy-iframe');
    if (iframe) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            iframe.src = iframe.dataset.src;
            observer.disconnect();
          }
        });
      }, { rootMargin: '200px' });
      observer.observe(iframe);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initContactForm);
  } else {
    initContactForm();
  }
</script>