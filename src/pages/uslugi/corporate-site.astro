---
import Layout from '../../layouts/Layout.astro'
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Faq from "../../components/Faq.astro";
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Разработка корпоративных сайтов",
  "name": "Разработка корпоративных сайтов на заказ",
  "description": "Многостраничный сайт для клиник, студий и агентств — структура, CMS, аналитика по запросу.",
  "provider": {
    "@type": "Organization",
    "name": "site2u.by"
  },
  "areaServed": "BY"
}
const faqItems = [
  {question: 'Поможете с доменом и хостингом?', answer: 'Да, поможем подобрать и настроить домен и хостинг.'},
  {
    question: 'Можно ли добавить страницы после запуска?',
    answer: 'Да, структуру сайта можно расширять по мере роста бизнеса.'
  },
  {
    question: 'Обязательно ли подключать CMS?',
    answer: 'Нет. Подключаем CMS, если вы хотите самостоятельно менять тексты и фотографии после запуска сайта.'
  }
];

const breadcrumbItems = [
  {label: "Главная", href: "/"},
  {label: "Услуги", href: "/uslugi"},
  {label: "Корпоративный сайт", href: "/uslugi/corporate-site"}
];
---
<Layout title="Разработка корпоративных сайтов  на заказ в Беларуси | site2u.by"
        description="Многостраничный сайт для клиник, студий и агентств — структура, CMS, аналитика по запросу."
        serviceSchema={serviceSchema}>
  <Breadcrumbs items={breadcrumbItems}/>

  <div class="service-detail page--padded">
    <div class="container">
    <div class="service-detail__heading-block">
      <h1 class="page-heading">Корпоративный сайт для компании</h1>
      <span class="service-detail__rule"></span>
    </div>

    <p class="service-detail__lead">
      Подходит для клиник, студий, агентств и других компаний, которым важно подробно рассказать о себе, услугах и способах связи с клиентами.
    </p>

    <section class="service-features">
      <h2 class="block-heading">Что вы получаете</h2>
      <div class="service-features__grid">
        <div class="feature-item card">
          <svg class="feature-item__icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
                  stroke-linejoin="round"/>
          </svg>
          <p>Структура из нескольких ключевых страниц: о компании, услуги, контакты</p>
        </div>
        <div class="feature-item card">
          <svg class="feature-item__icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
                  stroke-linejoin="round"/>
          </svg>
          <p>Единый стиль и удобная навигация между разделами</p>
        </div>
        <div class="feature-item card">
          <svg class="feature-item__icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
                  stroke-linejoin="round"/>
          </svg>
          <p>Сайт корректно отображается на компьютерах, планшетах и смартфонах</p>
        </div>
        <div class="feature-item card">
          <svg class="feature-item__icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
                  stroke-linejoin="round"/>
          </svg>
          <p>Быстрая загрузка страниц для комфортного просмотра</p>
        </div>
        <div class="feature-item card block--accent-border">
          <svg class="feature-item__icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
                  stroke-linejoin="round"/>
          </svg>
          <p>Самостоятельное редактирование текстов и фотографий (CMS)</p>
        </div>
        <div class="feature-item card block--accent-border">
          <svg class="feature-item__icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
                  stroke-linejoin="round"/>
          </svg>
          <p>Подключение Google Analytics и Яндекс.Метрики</p>
        </div>
        <div class="feature-item card block--accent-border">
          <svg class="feature-item__icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
                  stroke-linejoin="round"/>
          </svg>
          <p>Отслеживание заявок и других действий посетителей</p>
        </div>
      </div>
      <p class="service-features__hint">Базовое + Опционально (по согласованию)</p>
      <p class="service-features__text block--accent-border">Для большинства корпоративных сайтов мы рекомендуем техническую подготовку к продвижению, так как такие сайты обычно рассчитаны на долгосрочную работу и привлечение посетителей из поисковых систем.</p>
    </section>

    <section class="service-design">
      <h2 class="block-heading">Работа с дизайном</h2>
      <div class="service-design__grid">
        <div class="design-option card">
          <h3>Если у вас уже есть макет</h3>
          <p>Соберём сайт по готовому макету и согласуем только важные детали</p>
        </div>
        <div class="design-option card">
          <h3>Если макета нет</h3>
          <p>Поможем разработать дизайн и согласуем его до начала разработки сайта</p>
        </div>
      </div>
    </section>

    <section class="service-detail__block">
      <h2 class="block-heading">SEO — по согласованию</h2>
      <p>Если важно, чтобы сайт находили через Google и Яндекс, можно подключить техническую подготовку к продвижению. Настроим структуру, мета-теги и другие базовые элементы сайта.</p>
    </section>

    <section class="service-stats">
      <div class="stat-block card">
        <span class="stat-block__number">3–4</span>
        <span class="stat-block__label">недели на разработку</span>
      </div>
      <div class="stat-block card">
        <span class="stat-block__number">100%</span>
        <span class="stat-block__label">оплата по факту готовой работы</span>
      </div>
    </section>

    <section class="service-detail__block">
      <h2 class="block-heading">После запуска</h2>
      <p>После запуска поможем разобраться с CMS и аналитикой, ответим на вопросы и останемся на связи.</p>
    </section>
    <Faq items={faqItems}/>
  </div>
  </div>
</Layout>

<style>
  .service-detail__lead {
    font-size: var(--font-size-md);
    color: var(--color-text-secondary);
    max-width: var(--container-sm);
    margin-bottom: var(--space-lg);
  }

  .service-features__text{
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
  max-width: var(--container-sm);
  margin: var(--space-lg) 0;
}
  .service-detail__block {
    max-width: var(--container-sm);
    margin-bottom: var(--space-xl);
  }

  .service-detail__block p {
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
  }

  .service-features {
    margin-bottom: var(--space-xl);
  }

  .service-features__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
  }

  .service-features__hint {
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
    text-align: center;
    margin-top: var(--space-sm);
    font-style: italic;
  }

  @media (max-width: 768px) {
    .service-features__grid {
      grid-template-columns: 1fr;
    }
  }

  .feature-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
    padding: var(--space-md);
  }

  .feature-item__icon {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    color: var(--color-accent-hover);
  }

  .feature-item p {
    margin: 0;
    font-size: var(--font-size-base);
    color: var(--color-text-primary);
  }

  .service-design {
    margin-bottom: var(--space-xl);
  }

  .service-design__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
  }

  .service-detail__rule {
    display: block;
    width: 130px;
    height: 2px;
    background: var(--color-accent);
    border-radius: var(--radius-full);
    margin-bottom: var(--space-sm);
  }

  @media (max-width: 768px) {
    .service-design__grid {
      grid-template-columns: 1fr;
    }
  }

  .design-option {
    border-radius: var(--radius-sm);
    padding: var(--space-md);
  }

  .design-option h3 {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    margin-bottom: var(--space-xs);
  }

  .design-option p {
    color: var(--color-text-secondary);
    font-size: var(--font-size-base);
  }

  .service-stats {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }

  /* ==========================================================================
   АДАПТИВНАЯ ВЕРСТКА: service-detail (корпоративный сайт)
   ========================================================================== */

  /* ===== Планшеты (до 992px) ===== */
  @media (max-width: 992px) {
    .service-detail__lead {
      font-size: var(--font-size-base);
      max-width: 100%;
      margin-bottom: var(--space-md);
    }

    .service-features__grid {
      gap: var(--space-sm);
    }

    .feature-item {
      padding: var(--space-sm);
      gap: var(--space-xs);
    }

    .feature-item p {
      font-size: var(--font-size-sm);
    }

    .service-design__grid {
      gap: var(--space-sm);
    }

    .design-option {
      padding: var(--space-sm);
    }

    .design-option h3 {
      font-size: var(--font-size-sm);
    }

    .design-option p {
      font-size: var(--font-size-sm);
    }

    .service-detail__block {
      max-width: 100%;
      margin-bottom: var(--space-lg);
    }

    .service-features__text {
      font-size: var(--font-size-base);
      max-width: 100%;
      margin: var(--space-md) 0;
    }

    .service-stats {
      gap: var(--space-sm);
    }

    .service-stats .stat-block {
      flex: 1;
      min-width: 140px;
    }
  }

  /* ===== Мобильные (до 768px) ===== */
  @media (max-width: 768px) {
    .service-detail__heading-block {
      margin-bottom: var(--space-sm);
    }

    .service-detail__rule {
      width: 80px;
      height: 2px;
      margin-bottom: var(--space-xs);
    }

    .service-detail__lead {
      font-size: var(--font-size-sm);
      margin-bottom: var(--space-md);
      line-height: var(--line-height-relaxed);
    }

    .service-features {
      margin-bottom: var(--space-lg);
    }

    .service-features__grid {
      grid-template-columns: 1fr;
      gap: var(--space-xs);
    }

    .feature-item {
      padding: var(--space-sm);
      gap: var(--space-xs);
      border-radius: var(--radius-sm);
    }

    .feature-item p {
      font-size: var(--font-size-sm);
      line-height: var(--line-height-relaxed);
    }

    .feature-item__icon {
      width: 20px;
      height: 20px;
    }

    .service-features__hint {
      font-size: 11px;
      margin-top: var(--space-xs);
    }

    .service-features__text {
      font-size: var(--font-size-sm);
      padding-left: var(--space-md);
      margin: var(--space-md) 0;
    }

    .service-design {
      margin-bottom: var(--space-lg);
    }

    .service-design__grid {
      grid-template-columns: 1fr;
      gap: var(--space-xs);
    }

    .design-option {
      padding: var(--space-sm);
      border-radius: var(--radius-sm);
    }

    .design-option h3 {
      font-size: var(--font-size-sm);
      margin-bottom: 4px;
    }

    .design-option p {
      font-size: var(--font-size-sm);
      line-height: var(--line-height-relaxed);
    }

    .service-detail__block {
      margin-bottom: var(--space-md);
    }

    .service-detail__block h2 {
      font-size: var(--font-size-base);
    }

    .service-detail__block p {
      font-size: var(--font-size-sm);
      line-height: var(--line-height-relaxed);
    }

    .service-stats {
      flex-direction: column;
      gap: var(--space-xs);
      margin-bottom: var(--space-lg);
    }

    .service-stats .stat-block {
      width: 100%;
      padding: var(--space-sm);
      min-width: 0;
    }

    .service-stats .stat-block__number {
      font-size: var(--font-size-xl);
    }

    .service-stats .stat-block__label {
      font-size: var(--font-size-sm);
    }

    /* Отключаем hover на мобильных */
    .feature-item:hover,
    .design-option:hover {
      transform: none;
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.07);
    }

    .service-stats .stat-block:hover {
      transform: none;
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.07);
    }
  }

  /* ===== Маленькие телефоны (до 480px) ===== */
  @media (max-width: 480px) {
    .service-detail__rule {
      width: 60px;
      height: 2px;
    }

    .service-detail__lead {
      font-size: var(--font-size-sm);
      margin-bottom: var(--space-sm);
    }

    .feature-item {
      padding: var(--space-xs);
      gap: 4px;
    }

    .feature-item p {
      font-size: var(--font-size-xs);
    }

    .feature-item__icon {
      width: 18px;
      height: 18px;
    }

    .service-features__text {
      font-size: var(--font-size-xs);
      padding-left: var(--space-sm);
      margin: var(--space-sm) 0;
    }

    .design-option {
      padding: var(--space-xs);
    }

    .design-option h3 {
      font-size: var(--font-size-xs);
    }

    .design-option p {
      font-size: var(--font-size-xs);
    }

    .service-detail__block h2 {
      font-size: var(--font-size-sm);
    }

    .service-detail__block p {
      font-size: var(--font-size-xs);
    }

    .service-stats .stat-block {
      padding: var(--space-xs);
    }

    .service-stats .stat-block__number {
      font-size: var(--font-size-lg);
    }

    .service-stats .stat-block__label {
      font-size: var(--font-size-xs);
    }

    /* Акцентная граница на мобильных */
    .block--accent-border {
      border-left-width: 2px;
      padding-left: var(--space-sm);
    }
  }

  /* ===== Очень узкие экраны (до 360px) ===== */
  @media (max-width: 360px) {
    .service-detail__lead {
      font-size: var(--font-size-xs);
    }

    .feature-item {
      padding: 6px;
    }

    .feature-item p {
      font-size: var(--font-size-xs);
      line-height: var(--line-height-relaxed);
    }

    .feature-item__icon {
      width: 16px;
      height: 16px;
    }

    .service-features__text {
      font-size: var(--font-size-xs);
      padding-left: var(--space-xs);
    }

    .design-option {
      padding: 6px;
    }

    .design-option h3 {
      font-size: var(--font-size-xs);
    }

    .design-option p {
      font-size: var(--font-size-xs);
    }

    .service-detail__block h2 {
      font-size: var(--font-size-xs);
    }

    .service-detail__block p {
      font-size: var(--font-size-xs);
    }

    .service-stats .stat-block {
      padding: 6px;
    }

    .service-stats .stat-block__number {
      font-size: var(--font-size-base);
    }

    .service-stats .stat-block__label {
      font-size: 11px;
    }

    .block--accent-border {
      padding-left: 6px;
    }
  }

  /* ==========================================================================
     ДОПОЛНИТЕЛЬНЫЕ УЛУЧШЕНИЯ
     ========================================================================== */

  /* Адаптация для сетки фич на больших планшетах */
  @media (min-width: 769px) and (max-width: 992px) {
    .service-features__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-sm);
    }

    .feature-item {
      padding: var(--space-md);
    }
  }

  /* Адаптация для длинных текстов в фичах */
  @media (max-width: 768px) {
    .feature-item p {
      word-break: break-word;
      hyphens: auto;
    }
  }

  /* Адаптация для stat-block в ряд на планшетах */
  @media (min-width: 769px) and (max-width: 992px) {
    .service-stats {
      flex-direction: row;
      gap: var(--space-sm);
    }

    .service-stats .stat-block {
      flex: 1;
      min-width: 120px;
    }
  }

  /* Улучшение читаемости на мобильных */
  @media (max-width: 768px) {
    .service-detail__heading-block .page-heading {
      font-size: var(--font-size-xl);
      margin-bottom: var(--space-xs);
    }
  }

  @media (max-width: 480px) {
    .service-detail__heading-block .page-heading {
      font-size: var(--font-size-lg);
    }
  }

  @media (max-width: 360px) {
    .service-detail__heading-block .page-heading {
      font-size: var(--font-size-base);
    }
  }
</style>
