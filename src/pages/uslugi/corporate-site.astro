---
import Layout from '../../layouts/Layout.astro'
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Faq from "../../components/Faq.astro";
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Разработка корпоративных сайтов",
  "name": "Разработка корпоративных сайтов на заказ",
  "description": "Многостраничный сайт для клиник, студий и агентств — структура, CMS, аналитика по запросу.",
  "provider": {
    "@type": "Organization",
    "name": "site2u.by"
  },
  "areaServed": "BY"
}
const faqItems = [
  {question: 'Поможете с доменом и хостингом?', answer: 'Да, поможем подобрать и настроить домен и хостинг.'},
  {
    question: 'Можно ли добавить страницы после запуска?',
    answer: 'Да, структуру сайта можно расширять по мере роста бизнеса.'
  },
  {
    question: 'Обязательно ли подключать CMS?',
    answer: 'Нет, это опция — подключаем, если хотите менять тексты и фото самостоятельно.'
  }
];

const breadcrumbItems = [
  {label: "Главная", href: "/"},
  {label: "Услуги", href: "/uslugi"},
  {label: "Корпоративный сайт", href: "/uslugi/corporate-site"}
];
---
<Layout title="Разработка корпоративных сайтов  на заказ в Беларуси | site2u.by"
        description="Многостраничный сайт для клиник, студий и агентств — структура, CMS, аналитика по запросу."
        serviceSchema={serviceSchema}>
  <Breadcrumbs items={breadcrumbItems}/>

  <div class="service-detail container">
    <div class="service-detail__heading-block">
      <h1 class="page-heading">Корпоративный сайт для постоянного присутствия в сети</h1>
      <span class="service-detail__rule"></span>
    </div>

    <p class="service-detail__lead">
      Клиники, студии, агентства — бизнесы, которым нужно не разовое промо, а постоянное представительство в сети. Сайт,
      который работает на репутацию и доверие 24/7.
    </p>

    <section class="service-features">
      <h2 class="block-heading">Что вы получаете</h2>
      <div class="service-features__grid">
        <div class="feature-item">
          <svg class="feature-item__icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
                  stroke-linejoin="round"/>
          </svg>
          <p>Структура из нескольких ключевых страниц: о компании, услуги, контакты</p>
        </div>
        <div class="feature-item">
          <svg class="feature-item__icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
                  stroke-linejoin="round"/>
          </svg>
          <p>Единый стиль и удобная навигация между разделами</p>
        </div>
        <div class="feature-item">
          <svg class="feature-item__icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
                  stroke-linejoin="round"/>
          </svg>
          <p>Адаптивная вёрстка — одинаково хорошо работает на всех устройствах</p>
        </div>
        <div class="feature-item">
          <svg class="feature-item__icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
                  stroke-linejoin="round"/>
          </svg>
          <p>Быстрая загрузка страниц для комфортного просмотра</p>
        </div>
        <div class="feature-item feature-item--optional">
          <svg class="feature-item__icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
                  stroke-linejoin="round"/>
          </svg>
          <p>CMS для самостоятельного редактирования контента</p>
        </div>
        <div class="feature-item feature-item--optional">
          <svg class="feature-item__icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
                  stroke-linejoin="round"/>
          </svg>
          <p>Google Analytics + Яндекс.Метрика для анализа трафика</p>
        </div>
        <div class="feature-item feature-item--optional">
          <svg class="feature-item__icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
                  stroke-linejoin="round"/>
          </svg>
          <p>Отслеживание действий пользователей для оптимизации</p>
        </div>
      </div>
      <p class="service-features__hint">Базовое + Опционально (по согласованию)</p>
    </section>

    <section class="service-design">
      <h2 class="block-heading">Работа с дизайном</h2>
      <div class="service-design__grid">
        <div class="design-option">
          <h3>Если у вас уже есть макет</h3>
          <p>Соберём сайт точно по макету — без лишних созвонов и согласований.</p>
        </div>
        <div class="design-option">
          <h3>Если макета нет</h3>
          <p>Подключим дизайнера, согласуем дизайн до начала разработки.</p>
        </div>
      </div>
    </section>

    <section class="service-detail__block">
      <h2 class="block-heading">SEO — по согласованию</h2>
      <p>Для корпоративного сайта, который должен находиться в поиске самостоятельно, рекомендуем SEO-оптимизацию.
        Настроим мета-теги, структуру и контент для лучшего ранжирования.</p>
    </section>

    <section class="service-stats">
      <div class="stat-block">
        <span class="stat-block__number">3–4</span>
        <span class="stat-block__label">недели на разработку</span>
      </div>
      <div class="stat-block">
        <span class="stat-block__number">100%</span>
        <span class="stat-block__label">оплата по факту готовой работы</span>
      </div>
    </section>

    <section class="service-detail__block">
      <h2 class="block-heading">После запуска</h2>
      <p>Консультируем по работе с сайтом, помогаем разобраться с CMS и системой аналитики — остаёмся на связи и после
        сдачи проекта.</p>
    </section>
    <Faq items={faqItems}/>
  </div>
</Layout>

<style>
  .service-detail {
    padding: var(--space-3xl) 0;
  }

  .service-detail__lead {
    font-size: var(--font-size-md);
    color: var(--color-text-secondary);
    max-width: var(--container-sm);
    margin-bottom: var(--space-lg);
  }


  .service-detail__block {
    max-width: var(--container-sm);
    margin-bottom: var(--space-xl);
  }

  .service-detail__block p {
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
  }

  .service-features {
    margin-bottom: var(--space-xl);
  }

  .service-features__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
  }

  .service-features__hint {
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
    text-align: center;
    margin-top: var(--space-sm);
    font-style: italic;
  }

  .feature-item,
  .design-option {
    transition: var(--transition-transform), box-shadow var(--transition-base);
  }

  .feature-item:hover,
  .design-option:hover,
  .stat-block:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
  }

  @media (max-width: 768px) {
    .service-features__grid {
      grid-template-columns: 1fr;
    }
  }

  .feature-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
    background: var(--color-bg-secondary);
    border-radius: var(--radius-sm);
    padding: var(--space-md);
  }

  .feature-item--optional {
    background: var(--color-bg-secondary);
    border: 2px dashed var(--color-accent);
    border-radius: var(--radius-sm);
  }

  .feature-item__icon {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    color: var(--color-accent-hover);
  }

  .feature-item p {
    margin: 0;
    font-size: var(--font-size-base);
    color: var(--color-text-primary);
  }

  .service-design {
    margin-bottom: var(--space-xl);
  }

  .service-design__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
  }

  .service-detail__rule {
    display: block;
    width: 130px;
    height: 2px;
    background: var(--color-accent);
    border-radius: var(--radius-full);
    margin-bottom: var(--space-sm);
  }

  @media (max-width: 768px) {
    .service-design__grid {
      grid-template-columns: 1fr;
    }
  }

  .design-option {
    border: 1px solid var(--color-divider);
    border-radius: var(--radius-sm);
    padding: var(--space-md);
  }

  .design-option h3 {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    margin-bottom: var(--space-xs);
  }

  .design-option p {
    color: var(--color-text-secondary);
    font-size: var(--font-size-base);
  }

  .service-stats {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }
</style>
