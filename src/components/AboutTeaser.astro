---
const stats = [
  { number: '2001', label: 'IMC Computers работает с 2001 года' },
  { number: '24+', label: 'года на рынке Беларуси' },
  { number: '3', label: 'направления работы' },
  { number: 'B2B', label: 'работаем с бизнесом' }
];
---
<section class="about-teaser section--padded">
  <div class="container">
    <h2 class="section-heading">О нас </h2>
    <p class="section-heading__subtitle">Веб-направление <a href="https://www.imc.by" target="_blank" rel="noopener" class="about-page__link" data-astro-cid-zhe6yam7="">IMC Computers</a>— создаём лендинги и сайты услуг, подбирая решение под задачи каждого бизнеса. </p>
    <div class="about-teaser__grid">
      <div class="about-teaser__text">
        <h3 class="block-heading">Разрабатываем сайты для бизнеса с понятным процессом и прозрачными условиями.</h3>
        <p>SITE2U — веб-направление IMC Computers. Работаем на базе компании с более чем 24-летним опытом, офисом в Минске и фокусом на B2B-проектах.</p>
        <p>Наш фокус — сайты услуг, представительские сайты и лендинги.</p>
        <a href="/o-nas" class="about-teaser__link">Подробнее о нас →</a>
      </div>

      <div class="about-teaser__stats">
        {stats.map((stat) => (
            <div class="stat-block card">
              <span class="stat-block__number">{stat.number}</span>
              <span class="stat-block__label">{stat.label}</span>
            </div>
        ))}
      </div>
    </div>
  </div>
</section>
<style>
  .about-teaser{
    background: var(--color-bg-secondary);
  }

  .about-teaser__grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--space-2xl);
    align-items: center;
  }

  .about-teaser__text p {
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
    margin: var(--space-sm) 0 var(--space-md);
  }

  .about-teaser__link {
    display: inline-block;
    color: var(--color-accent-hover);
    font-weight: var(--font-weight-semibold);
    transition: var(--transition-color);
  }

  .about-teaser__link:hover {
    color: var(--color-text-primary);
  }

  .about-teaser__stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-sm);
  }


  /* ==========================================================================
     АДАПТИВНАЯ ВЕРСТКА: about-teaser
     ========================================================================== */

  /* ===== Планшеты (768px - 991px) ===== */
  @media (max-width: 991px) {
    .about-teaser__grid {
      gap: var(--space-xl);
    }

    .about-teaser__stats {
      gap: var(--space-xs);
    }

    .stat-block {
      padding: var(--space-md) var(--space-sm);
      min-width: 120px;
    }

    .stat-block__number {
      font-size: var(--font-size-xl);
    }

    .stat-block__label {
      font-size: var(--font-size-sm);
    }
  }

  /* ===== Мобильные (до 767px) ===== */
  @media (max-width: 767px) {
    .about-teaser__grid {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    .about-teaser__text {
      order: 1;
    }

    .about-teaser__stats {
      order: 2;
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-xs);
    }

    .stat-block {
      padding: var(--space-sm);
      min-width: 0;
    }

    .stat-block__number {
      font-size: var(--font-size-xl);
    }

    .stat-block__label {
      font-size: var(--font-size-sm);
      line-height: var(--line-height-tight);
    }

    .about-teaser__text p {
      margin: var(--space-xs) 0 var(--space-sm);
    }

    .about-teaser__link {
      margin-top: var(--space-xs);
    }
  }

  /* ===== Маленькие телефоны (до 480px) ===== */
  @media (max-width: 480px) {
    .about-teaser__stats {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-xs);
    }

    .stat-block {
      padding: var(--space-sm) var(--space-xs);
    }

    .stat-block__number {
      font-size: var(--font-size-lg);
      margin-bottom: 4px;
    }

    .stat-block__label {
      font-size: var(--font-size-xs);
    }

    .section-heading {
      font-size: var(--font-size-2xl);
    }

    .section-heading__subtitle {
      font-size: var(--font-size-base);
      margin-bottom: var(--space-md);
      padding: 0 5px;
    }

    .block-heading {
      font-size: var(--font-size-md);
    }

    .about-teaser__text p {
      font-size: var(--font-size-sm);
      line-height: var(--line-height-relaxed);
    }

    .about-teaser__link {
      font-size: var(--font-size-sm);
    }
  }

  /* ===== Очень узкие экраны (до 360px) ===== */
  @media (max-width: 360px) {
    .about-teaser__stats {
      grid-template-columns: 1fr 1fr;
      gap: 6px;
    }

    .stat-block {
      padding: var(--space-xs);
    }

    .stat-block__number {
      font-size: var(--font-size-md);
    }

    .stat-block__label {
      font-size: 12px;
    }

    .container {
      padding: 0 12px;
    }
  }

  </style>