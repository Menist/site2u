---
const process = [
  {
    number: '01',
    title: 'Обсуждение',
    items: ['Обсуждаем проект и цели бизнеса', 'Определяем структуру сайта и состав страниц', 'Договариваемся о сроках и бюджете']
  },
  {
    number: '02',
    title: 'Макет и дизайн',
    items: ['Работаем с готовым макетом или создаём дизайн для вас', 'Все решения по дизайну согласуются до начала разработки']
  },
  {
    number: '03',
    title: 'Разработка',
    items: ['Разрабатываем сайт и подключаем необходимые сервисы', 'При необходимости подключаем CMS, аналитику и SEO-подготовку сайта', 'Проверяем работу сайта в современных браузерах и на разных устройствах']
  },
  {
    number: '04',
    title: 'Запуск',
    items: ['Помогаем разместить сайт на хостинге', 'Настраиваем домен и защищённое соединение (HTTPS)', 'Передаём проект и остаёмся на связи после запуска']
  }
];
---

<section class="process section--padded">
  <div class="container">
    <h2 class="section-heading">Как мы создаём сайты</h2>
    <p class="section-heading__subtitle">Проект проходит через понятные этапы — от обсуждения идеи до запуска сайта. Каждый следующий этап начинается только после согласования предыдущего.</p>

    <div class="process__grid">
      {process.map((step) => (
          <div class="process__card card">
            <span class="process__number">{step.number}</span>
            <h3 class="process__title">{step.title}</h3>
            <ul class="process__list">
              {step.items.map((item) => (
                  <li>{item}</li>
              ))}
            </ul>
          </div>
      ))}
    </div>
  </div>
</section>

<style>
  .process{
    background: var(--color-bg-secondary);
  }
  .process__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-md);
  }

  @media (max-width: 992px) {
    .process__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 576px) {
    .process__grid {
      grid-template-columns: 1fr;
    }
  }

  .process__card {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  .process__number {
    display: block;
    font-size: var(--font-size-3xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-accent);
    line-height: 1;
  }

  .process__title {
    font-size: var(--font-size-md);
    font-weight: var(--font-weight-semibold);
  }

  .process__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding-left: 0;
  }

  .process__list li {
    color: var(--color-text-secondary);
    padding-left: var(--space-sm);
    position: relative;
    line-height: var(--line-height-relaxed);
  }

  .process__list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 5px;
    height: 5px;
    border-radius: var(--radius-circle);
    background: var(--color-accent);
  }
</style>