---
// src/components/sections/Hero.astro
import HeroTitle from '../../src/components/HeroTitle.astro';
---

<section class="hero">
  <div class="hero__bg"></div>
  <div class="hero__overlay"></div>
  <div class="hero__container">
    <div class="container hero__content">
      <!-- Используем компонент с серверным разбиением слов -->
      <HeroTitle text="Сайты для бизнеса в Беларуси" />

      <p class="hero__subtitle">
        Разрабатываем сайты услуг, лендинги, визитки и промо-страницы.
        Если у вас уже есть макет — реализуем его. Если нет — поможем с дизайном и подготовим проект с нуля.
      </p>

      <a href="/kontakty" class="hero__cta" data-track="hero_cta">
        Обсудить проект
      </a>
    </div>

    <a href="#services" class="hero__arrow" aria-label="Перейти к услугам">
      <span class="hero__arrow-icon"></span>
    </a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: -70px 0;
    background-color: #16213e;
    background-image: url('/images/hero-bg.webp');
    background-size: cover;
    background-position: center;
    opacity: 0;
    transition: opacity 0.5s ease-in;
    transform: translateY(var(--hero-bg-shift-y, 0px));
    will-change: transform, opacity;
    z-index: 0;
  }

  .hero__bg.loaded {
    opacity: 1;
  }

  .hero__container {
    position: relative;
    z-index: 2;
    width: 100%;
    min-height: 100vh;
    margin: 0 auto;
    padding: 0 var(--space-lg);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }

  .hero__overlay {
    position: absolute;
    inset: -70px 0;
    background: var(--color-overlay-dark);
    z-index: 1;
    transform: translateY(var(--hero-overlay-shift-y, 0px));
    opacity: var(--hero-overlay-opacity, 1);
    will-change: transform, opacity;
  }

  .hero__content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: var(--color-white);
    transform: translateY(var(--hero-content-shift-y, 0px));
    will-change: transform;
  }

  .hero__subtitle {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-light);
    line-height: var(--line-height-relaxed);
    max-width: var(--container-sm);
    margin: 0 auto var(--space-lg);
    opacity: 0; /* скрыт до анимации */
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.7);
  }

  .hero__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 290px;
    height: 60px;
    padding: 0 var(--space-xl);
    border-radius: var(--radius-full);
    background-color: var(--color-accent);
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-bold);
    color: var(--color-white);
    transition: var(--transition-bg), var(--transition-transform);
    opacity: 0; /* скрыт до анимации */
  }

  .hero__cta:hover {
    background: var(--color-accent-hover);
  }

  .hero__arrow {
    position: absolute;
    cursor: pointer;
    left: 50%;
    bottom: 38px;
    transform: translateX(-50%);
    opacity: 0; /* скрыт до анимации */
  }

  .hero__arrow:hover .hero__arrow-icon {
    border-color: var(--color-accent);
  }

  .hero__arrow-icon {
    display: block;
    width: 22px;
    height: 22px;
    border-right: 3px solid var(--color-white);
    border-bottom: 3px solid var(--color-white);
    transform: rotate(45deg);
    transition: border-color var(--transition-base);
  }

  /* Для пользователей с отключенной анимацией */
  @media (prefers-reduced-motion: reduce) {
    .hero__subtitle,
    .hero__cta,
    .hero__arrow {
      opacity: 1 !important;
    }
  }
</style>

<script>
  import '../../src/scripts/hero-motion';
</script>