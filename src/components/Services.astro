---
import ServiceCard from './ServiceCard.astro';
---
<section class="services section--padded" id="services">
  <div class="container">
    <div class="services__header">
      <h2 class="section-heading">Наши услуги</h2>
      <p class="section-heading__subtitle">
        Подберем формат веб‑сайта под ваши задачи.
      </p>
    </div>

    <div class="services__grid">
      <ServiceCard
          title="Лендинг"
          forText="рассказать об одной услуге или собрать заявки. Кафе, салоны, мероприятия, промо-проекты."
          items={[
            'Адаптивный дизайн под все устройства',
            'Оптимизация скорости загрузки',
            'Форма заявки или кнопка в мессенджер',
            'Настройка аналитики для отслеживания заявок'
          ]}
          term="Срок зависит от объёма и макета"
          btnText="Обсудить лендинг"
          btnHref="/uslugi/landing/"
      >
        <svg slot="icon" width="100" height="100" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="4" y="8" width="56" height="48" rx="4" stroke="#ffbe49" stroke-width="2.5" fill="none"/>
          <line x1="4" y1="20" x2="60" y2="20" stroke="#ffbe49" stroke-width="2"/>
          <rect x="12" y="28" width="16" height="20" rx="2" stroke="#ffbe49" stroke-width="2" fill="none"/>
          <line x1="36" y1="28" x2="52" y2="28" stroke="#ffbe49" stroke-width="2"/>
          <line x1="36" y1="36" x2="52" y2="36" stroke="#ffbe49" stroke-width="2"/>
          <line x1="36" y1="44" x2="46" y2="44" stroke="#ffbe49" stroke-width="2"/>
          <circle cx="12" cy="14" r="2" fill="#ffbe49"/>
          <circle cx="20" cy="14" r="2" fill="#ffbe49"/>
          <circle cx="28" cy="14" r="2" fill="#ffbe49"/>
        </svg>
      </ServiceCard>

      <ServiceCard
          title="Корпоративный веб‑сайт"
          forText="представить компанию и несколько направлений деятельности. Клиники, студии, агентства."
          items={[
            'Несколько страниц: о нас, услуги, контакты',
            'Удобное управление текстами и фотографиями через CMS',
            'Подключение аналитики (Google Analytics и Яндекс.Метрика)',
            'Настройка отслеживания заявок и других действий посетителей'
          ]}
          term="Срок обсуждается индивидуально"
          btnText="Обсудить веб‑сайт"
          btnHref="/uslugi/corporate-site/"
          primary={true}
      >
        <svg slot="icon" width="100" height="100" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="4" y="10" width="56" height="36" rx="4" stroke="#ffbe49" stroke-width="2.5" fill="none"/>
          <line x1="24" y1="46" x2="40" y2="46" stroke="#ffbe49" stroke-width="2.5"/>
          <line x1="32" y1="46" x2="32" y2="54" stroke="#ffbe49" stroke-width="2.5"/>
          <line x1="22" y1="54" x2="42" y2="54" stroke="#ffbe49" stroke-width="2.5"/>
          <line x1="4" y1="38" x2="60" y2="38" stroke="#ffbe49" stroke-width="2"/>
          <circle cx="32" cy="24" r="8" stroke="#ffbe49" stroke-width="2" fill="none"/>
          <line x1="32" y1="18" x2="32" y2="30" stroke="#ffbe49" stroke-width="1.5"/>
          <line x1="26" y1="24" x2="38" y2="24" stroke="#ffbe49" stroke-width="1.5"/>
        </svg>
      </ServiceCard>
    </div>
  </div>
</section>

<style>

  .services__subtitle {

  }

  .services__grid {
    display: flex;
    justify-content: space-between;
    gap: var(--space-lg);
  }

  /* ==========================================================================
     АДАПТИВНАЯ ВЕРСТКА: services
     ========================================================================== */

  /* ===== Планшеты (до 992px) ===== */
  @media (max-width: 992px) {
    .services__grid {
      flex-direction: column;
      gap: var(--space-md);
      align-items: center;
    }

    .services__grid .service-card {
      width: 100%;
      max-width: 560px;
    }

    .services__header {
      margin-bottom: var(--space-md);
    }
  }

  /* ===== Мобильные (до 768px) ===== */
  @media (max-width: 768px) {
    .services__grid {
      flex-direction: column;
      gap: var(--space-sm);
      align-items: stretch;
    }

    .services__grid .service-card {
      width: 100%;
      max-width: 100%;
      padding: var(--space-md);
    }

    .services__header {
      margin-bottom: var(--space-sm);
    }

    /* Убираем hover-эффекты на мобильных */
    .services__grid .service-card:hover {
      transform: none;
      box-shadow: var(--shadow-card);
    }

    .services__grid .service-card--primary:hover {
      transform: none;
      box-shadow: var(--shadow-card);
    }
  }

  /* ===== Маленькие телефоны (до 480px) ===== */
  @media (max-width: 480px) {
    .services__grid {
      gap: var(--space-sm);
    }

    .services__grid .service-card {
      padding: var(--space-sm);
    }

    .services__header {
      margin-bottom: var(--space-xs);
    }

    /* Адаптация иконок */
    .services__grid .service-card__icon svg {
      width: 60px;
      height: 60px;
    }
  }

  /* ===== Очень узкие экраны (до 360px) ===== */
  @media (max-width: 360px) {
    .services__grid .service-card {
      padding: var(--space-xs);
    }

    .services__grid .service-card__icon svg {
      width: 48px;
      height: 48px;
    }
  }

  /* ==========================================================================
     ДОПОЛНИТЕЛЬНЫЕ УЛУЧШЕНИЯ
     ========================================================================== */

  /* Если карточки должны быть в 2 колонки на больших экранах */
  @media (min-width: 993px) {
    .services__grid {
      display: flex;
      justify-content: center;
      gap: var(--space-lg);
      align-items: stretch;
    }

    .services__grid .service-card {
      width: calc(50% - var(--space-lg) / 2);
      max-width: 560px;
    }

    /* Выравнивание высоты карточек */
    .services__grid .service-card {
      display: flex;
      flex-direction: column;
      height: auto;
      min-height: 100%;
    }

    .services__grid .service-card__body {
      flex: 0 1 auto;
    }

    .services__grid .service-card__list {
      flex: 1 0 auto;
    }

    .services__grid .service-card__footer {
      margin-top: auto;
    }
  }

  /* Для экранов между 769px и 992px (планшеты) */
  @media (min-width: 769px) and (max-width: 992px) {
    .services__grid {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
      gap: var(--space-md);
    }

    .services__grid .service-card {
      width: calc(50% - var(--space-md) / 2);
      max-width: 440px;
    }
  }

  /* Улучшение читаемости на мобильных */
  @media (max-width: 768px) {
    .services__grid .service-card__list {
      text-align: left;
      padding-left: 0;
    }

    .services__grid .service-card__list li {
      text-align: left;
    }

    .services__grid .service-card__for {
      text-align: center;
    }

    .services__grid .service-card__term {
      text-align: center;
    }

    .services__grid .service-card__btn {
      margin-left: auto;
      margin-right: auto;
    }
  }

  /* Адаптация для очень длинных текстов в списке */
  @media (max-width: 480px) {
    .services__grid .service-card__list li {
      word-break: break-word;
      hyphens: auto;
    }
  }

  /* Адаптация для устройств с сенсорным управлением */
  @media (hover: none) {
    .services__grid .service-card:hover {
      transform: none !important;
      box-shadow: var(--shadow-card) !important;
    }

    .services__grid .service-card--primary:hover {
      transform: none !important;
      box-shadow: var(--shadow-card) !important;
    }

    .services__grid .service-card__btn:hover {
      transform: none !important;
    }
  }
</style>