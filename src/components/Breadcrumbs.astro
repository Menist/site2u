---
interface Props {
  items: { label: string; href: string }[]
}
const {items} = Astro.props;
const breadcrumbItems  = items.map((el, i) => {
  return {
    '@type': "ListItem",
    'position': i + 1,
    'name': el.label,
    'item': new URL(el.href, Astro.site)
  }
})
const breadcrumbSchema={
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbItems
}
---
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)}/>

<div class="container">
<nav class="breadcrumbs ">
  {items.map((el, index) => (
    index === items.length - 1
      ? <span>{el.label}</span>
      : <a href={el.href}>{el.label}</a>
  ))}
</nav>
</div>

<style>
  .breadcrumbs {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
    margin-top: var(--space-lg);
    margin-bottom: var(--space-sm);
  }

  .breadcrumbs a {
    color: var(--color-text-secondary);
    transition: var(--transition-color);
  }

  .breadcrumbs a:hover {
    color: var(--color-accent-hover);
  }

  .breadcrumbs a:not(:last-child)::after {
    content: '→';
    margin-left: var(--space-xs);
    color: var(--color-divider);
  }

  /* ==========================================================================
   АДАПТИВНАЯ ВЕРСТКА: breadcrumbs
   ========================================================================== */

  /* ===== Планшеты (до 768px) ===== */
  @media (max-width: 768px) {
    .breadcrumbs {
      gap: 6px;
      font-size: var(--font-size-xs);
      margin-top: var(--space-md);
      margin-bottom: var(--space-xs);
    }

    .breadcrumbs a:not(:last-child)::after {
      margin-left: 6px;
    }
  }

  /* ===== Мобильные (до 576px) ===== */
  @media (max-width: 576px) {
    .breadcrumbs {
      gap: 4px;
      font-size: 12px;
      margin-top: var(--space-sm);
      margin-bottom: 6px;
      flex-wrap: wrap;
    }

    .breadcrumbs a,
    .breadcrumbs span {
      padding: 2px 0;
      white-space: nowrap;
    }

    .breadcrumbs a:not(:last-child)::after {
      margin-left: 4px;
      margin-right: 0;
    }

    /* Ограничиваем количество видимых крошек на мобильных */
    .breadcrumbs a:nth-child(n+4):not(:last-child) {
      display: none;
    }

    /* Показываем ... перед последним элементом */
    .breadcrumbs a:nth-child(3):not(:last-child)::after {
      content: '... →';
      margin-left: 4px;
    }

    /* Скрываем стрелку у скрытых элементов */
    .breadcrumbs a:nth-child(n+4):not(:last-child)::after {
      content: '';
      display: none;
    }
  }

  /* ===== Очень узкие экраны (до 400px) ===== */
  @media (max-width: 400px) {
    .breadcrumbs {
      font-size: 11px;
      gap: 3px;
      margin-top: var(--space-xs);
      margin-bottom: 4px;
    }

    .breadcrumbs a:not(:last-child)::after {
      margin-left: 3px;
    }

    /* На очень узких показываем только первый и последний */
    .breadcrumbs a:nth-child(n+2):not(:last-child) {
      display: none;
    }

    .breadcrumbs a:first-child:not(:last-child)::after {
      content: '... →';
      margin-left: 3px;
    }
  }
</style>