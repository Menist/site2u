---
const features = [
  {
    title: 'Видимость в поиске',
    description: 'Сайт подготовлен так, чтобы поисковые системы могли читать, индексировать и понимать его структуру.',
    items: [
      'Видимость в Google и Яндексе',
      'Контент, доступный для поисковых систем',
      'Структурированные данные (Schema.org) для поисковых систем и AI-сервисов',
      'Карта сайта для индексации'
    ]
  },
  {
    title: 'Производительность сайта',
    description: 'Сайт оптимизирован для быстрой загрузки и стабильной работы на современных устройствах.',
    items: [
      'Быстрая загрузка',
      'Высокие показатели скорости (PageSpeed)',
      'Защищённое соединение (HTTPS)',
      'Разработка на современных технологиях'
    ]
  },
  {
    title: 'Управление контентом',
    description: 'После запуска вы сможете самостоятельно управлять контентом, отслеживать заявки и просматривать статистику.',
    items: [
      'Самостоятельное управление текстами и фотографиями (CMS)',
      'Подключение аналитики',
      'Отслеживание заявок',
      'Простое обновление контента'
    ]
  },
];
---
<section class="advantages section--padded">
  <div class="container">
    <h2 class="section-heading">Что можно включить в ваш проект</h2>
    <p class="section-heading__subtitle">Каждый проект разрабатывается индивидуально. Мы не используем шаблонный набор функций — вместе определяем, какие функции действительно нужны вашему проекту, и согласовываем их до начала разработки.</p>

    <div class="advantages__grid">
      {features.map((feature) => (
          <div class="advantages__card card">
            <h3 class="advantages__title">{feature.title}</h3>
            <p class="advantages__description">{feature.description}</p>
            <ul class="advantages__list">
              {feature.items.map((item) => (
                  <li>{item}</li>
              ))}
            </ul>
          </div>
      ))}
    </div>
  </div>
</section>

<style>
  .advantages__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  @media (max-width: 768px) {
    .advantages__grid {
      grid-template-columns: 1fr;
    }
  }

  .advantages__card {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .advantages__title {
    font-size: var(--font-size-md);
    font-weight: var(--font-weight-semibold);
  }

  .advantages__description {
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
  }

  .advantages__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding-left: 0;
  }

  .advantages__list li {
    color: var(--color-text-secondary);
    padding-left: var(--space-sm);
    position: relative;
  }

  .advantages__list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 5px;
    height: 5px;
    border-radius: var(--radius-circle);
    background: var(--color-accent);
  }
</style>