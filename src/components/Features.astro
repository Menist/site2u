---
const features = [
  {
    title: 'Видимость в поиске',
    description: 'Веб‑сайт подготовлен так, чтобы поисковые системы могли читать, индексировать и понимать его структуру.',
    items: [
      'Видимость в Google и Яндексе',
      'Контент, доступный для поисковых систем',
      'Структурированные данные (Schema.org) для поисковых систем и AI-сервисов',
      'Карта веб‑сайта для индексации'
    ]
  },
  {
    title: 'Производительность веб‑сайта',
    description: 'Веб‑сайт оптимизирован для быстрой загрузки и стабильной работы на современных устройствах.',
    items: [
      'Быстрая загрузка',
      'Высокие показатели скорости (PageSpeed)',
      'Защищённое соединение (HTTPS)',
      'Разработка на современных технологиях'
    ]
  },
  {
    title: 'Управление контентом',
    description: 'После запуска вы сможете самостоятельно управлять контентом, отслеживать заявки и просматривать статистику.',
    items: [
      'Самостоятельное управление текстами и фотографиями (CMS)',
      'Подключение аналитики',
      'Отслеживание заявок',
      'Простое обновление контента'
    ]
  },
];
---
<section class="advantages section--padded">
  <div class="container">
    <h2 class="section-heading">Что можно включить в ваш проект</h2>
    <p class="section-heading__subtitle">Каждый проект разрабатывается индивидуально. Мы не используем шаблонный набор функций — вместе определяем, какие функции действительно нужны вашему проекту, и согласовываем их до начала разработки.</p>

    <div class="advantages__grid">
      {features.map((feature) => (
          <div class="advantages__card card">
            <h3 class="advantages__title">{feature.title}</h3>
            <p class="advantages__description">{feature.description}</p>
            <ul class="advantages__list">
              {feature.items.map((item) => (
                  <li>{item}</li>
              ))}
            </ul>
          </div>
      ))}
    </div>
  </div>
</section>

<style>
  .advantages__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  @media (max-width: 768px) {
    .advantages__grid {
      grid-template-columns: 1fr;
    }
  }

  .advantages__card {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .advantages__title {
    font-size: var(--font-size-md);
    font-weight: var(--font-weight-semibold);
  }

  .advantages__description {
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
  }

  .advantages__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding-left: 0;
  }

  .advantages__list li {
    color: var(--color-text-secondary);
    padding-left: var(--space-sm);
    position: relative;
  }

  .advantages__list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 5px;
    height: 5px;
    border-radius: var(--radius-circle);
    background: var(--color-accent);
  }

  /* ==========================================================================
   АДАПТИВНАЯ ВЕРСТКА: advantages
   ========================================================================== */

  /* ===== Планшеты (до 992px) ===== */
  @media (max-width: 992px) {
    .advantages__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-sm);
    }

    .advantages__card {
      padding: var(--space-md);
      gap: var(--space-xs);
    }

    .advantages__title {
      font-size: var(--font-size-md);
    }

    .advantages__description {
      font-size: var(--font-size-sm);
    }

    .advantages__list li {
      font-size: var(--font-size-sm);
      padding-left: var(--space-sm);
    }

    .advantages__list li::before {
      top: 0.6em;
      width: 4px;
      height: 4px;
    }
  }

  /* ===== Мобильные (до 768px) ===== */
  @media (max-width: 768px) {
    .advantages__grid {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }

    .advantages__card {
      padding: var(--space-md);
      gap: var(--space-xs);
      border-radius: var(--radius-sm);
    }

    .advantages__title {
      font-size: var(--font-size-base);
    }

    .advantages__description {
      font-size: var(--font-size-sm);
      line-height: var(--line-height-relaxed);
    }

    .advantages__list {
      gap: 6px;
      margin-top: var(--space-xs);
    }

    .advantages__list li {
      font-size: var(--font-size-sm);
      padding-left: var(--space-sm);
      line-height: var(--line-height-relaxed);
    }

    .advantages__list li::before {
      top: 0.65em;
      width: 4px;
      height: 4px;
    }
  }

  /* ===== Маленькие телефоны (до 480px) ===== */
  @media (max-width: 480px) {
    .advantages__grid {
      gap: var(--space-sm);
    }

    .advantages__card {
      padding: var(--space-sm);
      gap: 4px;
      border-radius: var(--radius-sm);
    }

    .advantages__title {
      font-size: var(--font-size-sm);
      margin-bottom: 0;
    }

    .advantages__description {
      font-size: var(--font-size-xs);
      line-height: var(--line-height-relaxed);
      margin-bottom: 0;
    }

    .advantages__list {
      gap: 4px;
      margin-top: 4px;
    }

    .advantages__list li {
      font-size: var(--font-size-xs);
      padding-left: var(--space-sm);
      line-height: var(--line-height-relaxed);
    }

    .advantages__list li::before {
      top: 0.6em;
      width: 3px;
      height: 3px;
    }

    /* Убираем hover-эффект на мобильных */
    .advantages__card:hover {
      transform: none;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.10);
    }
  }

  /* ===== Очень узкие экраны (до 360px) ===== */
  @media (max-width: 360px) {
    .advantages__card {
      padding: var(--space-xs);
    }

    .advantages__title {
      font-size: var(--font-size-xs);
    }

    .advantages__description {
      font-size: 12px;
    }

    .advantages__list li {
      font-size: 12px;
      padding-left: var(--space-xs);
    }

    .advantages__list li::before {
      top: 0.55em;
      width: 3px;
      height: 3px;
    }
  }
</style>