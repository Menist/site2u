---
const navItems = [
  { label: "Главная", href: "/" },
  { label: "Корпоративные сайты", href: "/uslugi" },
  { label: "Лендинги", href: "/uslugi/landing" },
  { label: "Контакты", href: "/corporate-site" },
];
---
<footer class="footer">
  <div class="container">

    <div class="footer__grid">
      <div class="footer__brand">
        <span class="footer__logo">SITE2U</span>
        <p class="footer__desc">Веб-направление компании IMC Computers. Создаём сайты для бизнеса в Беларуси.</p>
      </div>

      <nav class="footer__nav">
        <p class="footer__nav-title">Навигация</p>
        <ul class="footer__nav-list">
          {navItems.map((item) => (
              <li><a href={item.href} class="footer__nav-link">{item.label}</a></li>
          ))}
        </ul>
      </nav>

      <div class="footer__contacts">
        <p class="footer__nav-title">Контакты</p>
        <ul class="footer__contacts-list">
          <li><a href="tel:+375296195265" class="footer__contact-link">+375 (29) 619-52-65</a></li>
          <li><a href="mailto:hello@site2u.by" class="footer__contact-link">hello@site2u.by</a></li>
          <li class="footer__address">Минск, проспект Независимости, 68-2, офис 108</li>
        </ul>
      </div>
    </div>

    <div class="footer__bottom">
      <p class="footer__copy">© 2026 site2u.by — IMC COMPUTERS LTD</p>
      <p class="footer__made">Разработка сайтов для бизнеса</p>
    </div>

  </div>
</footer>

<style>
  .footer {
    background: var(--color-bg-primary);
    border-top: 1px solid var(--color-divider);
    padding-top: var(--space-sm);
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: var(--space-2xl);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-divider);
  }

  @media (max-width: 768px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 480px) {
    .footer__grid {
      grid-template-columns: 1fr;
    }
  }

  .footer__logo {
    display: inline-block;
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    color: var(--color-text-primary);
    margin-bottom: var(--space-sm);
  }

  .footer__desc {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
    max-width: 260px;
  }

  .footer__nav-title {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-xs);
  }

  .footer__nav-list,
  .footer__contacts-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .footer__nav-link,
  .footer__contact-link {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    transition: var(--transition-color);
  }

  .footer__nav-link:hover,
  .footer__contact-link:hover {
    color: var(--color-accent-hover);
  }

  .footer__address {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
  }

  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-sm) 0;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .footer__copy,
  .footer__made {
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
  }
</style>