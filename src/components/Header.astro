---
import MobileMenu from './MobileMenu.astro';

const { transparent = false } = Astro.props;
interface Props {
  transparent?: boolean
}

const navItems = [
  {label: "Главная", href: "/"},
  {label: "Услуги", href: "/uslugi"},
  {label: "О нас", href: "/o-nas"},
  {label: "Контакты", href: "/kontakty"},
]

// Убираем trailing slash, чтобы /uslugi/ и /uslugi совпадали
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';

// Функция: / совпадает точно, остальные — по startsWith
function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname === href || pathname.startsWith(href + '/');
}
---

<header class={`header ${transparent ? 'header--transparent' : ''}`}>
  <nav class="hero__header">
    <ul class="hero__nav hero__nav--left">
      {navItems.slice(0, 2).map((el) => (
          <li class="hero__nav-item">
            <a
                href={el.href}
                class={`hero__nav-link ${isActive(el.href) ? 'active' : ''}`}
            >
              {el.label}
            </a>
          </li>
      ))}
    </ul>

    <a href="/" class="hero__logo" data-no-animation>
      SITE2U
    </a>

    <ul class="hero__nav hero__nav--right">
      {navItems.slice(2).map((el) => (
          <li class="hero__nav-item">
            <a
                href={el.href}
                class={`hero__nav-link ${isActive(el.href) ? 'active' : ''}`}
            >
              {el.label}
            </a>
          </li>
      ))}
    </ul>

    <!-- Кнопка бургер-меню (только на мобильных) -->
    <button class="hero__burger" id="burgerBtn" aria-label="Открыть меню" aria-expanded="false">
      <span class="hero__burger-line"></span>
      <span class="hero__burger-line"></span>
      <span class="hero__burger-line"></span>
    </button>
  </nav>
</header>

<MobileMenu navItems={navItems} />

<style>
  .header {
    width: 100%;
    padding: var(--space-sm) 0;
    position: relative;
    z-index: 10;
  }
  .header {
    background: var(--color-bg-secondary);
    border-bottom: 1px solid var(--color-divider);
  }

  .header--transparent {
    position: absolute;
    top: 0;
    left: 0;
    background: transparent;
    border-bottom: none;
  }

  .hero__header {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin: 0 auto;
    padding: var(--space-sm) var(--space-md);
  }

  .hero__nav {
    display: flex;
    align-items: center;
    gap: 38px;
  }

  .hero__nav-link {
    font-size: var(--font-size-md);
    font-weight: var(--font-weight-bold);
    color: var(--color-white);
    transition: var(--transition-color), var(--transition-opacity);
    text-decoration: none;
  }

  .hero__nav-link:hover {
    opacity: 0.7;
    color: var(--color-hero-nav-hover);
  }

  .hero__nav-link.active {
    color: var(--color-accent);
  }

  [data-no-animation] {
    animation: none !important;
    animation-name: none !important;
    animation-duration: 0s !important;
    transition: none !important;
    display: inline-block;
    min-width: 90px;
    white-space: nowrap;
  }

  .hero__logo {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    font-size: 22px;
    font-weight: var(--font-weight-bold);
    letter-spacing: 5px;
    color: var(--color-white);
    text-decoration: none;
    transition: color 0.3s ease, opacity 0.3s ease;
    display: inline-block;
    min-width: 90px;
    white-space: nowrap;
  }

  .hero__logo:hover {
    opacity: 0.7;
    color: var(--color-hero-nav-hover);
  }

  .header:not(.header--transparent) .hero__nav-link {
    color: var(--color-text-primary);
  }

  .header:not(.header--transparent) .hero__logo {
    color: var(--color-text-primary);
  }

  .header:not(.header--transparent) .hero__nav-link:hover {
    color: var(--color-accent);
  }

  /* Активная страница — желтая ссылка на обычном хедере */
  .header:not(.header--transparent) .hero__nav-link.active {
    color: var(--color-accent-hover);
  }

  .header:not(.header--transparent) .hero__nav-link.active:hover {
    opacity: 1;
    color: var(--color-accent-hover);
  }

  /* ===== Бургер-меню (кнопка) ===== */
  .hero__burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: var(--space-xs);
    background: transparent;
    border: none;
    cursor: pointer;
    min-height: var(--touch-target-min);
    min-width: var(--touch-target-min);
    justify-content: center;
    align-items: center;
    z-index: 1001;
  }

  .hero__burger-line {
    display: block;
    width: 28px;
    height: 2.5px;
    background: var(--color-text-primary);
    border-radius: var(--radius-full);
    transition: var(--transition-transform), var(--transition-opacity);
    transform-origin: center;
  }

  /* Цвет линий для прозрачного хедера */
  .header--transparent .hero__burger-line {
    background: var(--color-white);
  }

  /* Анимация бургера в крестик (при открытом меню) */
  .hero__burger.is-active .hero__burger-line:nth-child(1) {
    transform: translateY(7.5px) rotate(45deg);
  }

  .hero__burger.is-active .hero__burger-line:nth-child(2) {
    opacity: 0;
  }

  .hero__burger.is-active .hero__burger-line:nth-child(3) {
    transform: translateY(-7.5px) rotate(-45deg);
  }

  /* ===== Адаптив: показываем бургер на мобильных ===== */
  @media (max-width: 768px) {
    .hero__nav {
      display: none;
    }

    .hero__logo {
      position: static;
      transform: none;
    }

    .hero__header {
      justify-content: space-between;
    }

    .hero__burger {
      display: flex;
    }
  }

  @media (max-width: 480px) {
    .hero__burger-line {
      width: 24px;
      height: 2px;
    }

    .hero__burger.is-active .hero__burger-line:nth-child(1) {
      transform: translateY(6px) rotate(45deg);
    }

    .hero__burger.is-active .hero__burger-line:nth-child(3) {
      transform: translateY(-6px) rotate(-45deg);
    }

    .hero__logo {
      font-size: var(--font-size-base);
      min-width: 60px;
      letter-spacing: 2px;
    }
  }

  @media (max-width: 360px) {
    .hero__logo {
      font-size: var(--font-size-sm);
      min-width: 50px;
      letter-spacing: 1.5px;
    }

    .hero__burger-line {
      width: 20px;
      height: 2px;
    }

    .hero__burger.is-active .hero__burger-line:nth-child(1) {
      transform: translateY(5px) rotate(45deg);
    }

    .hero__burger.is-active .hero__burger-line:nth-child(3) {
      transform: translateY(-5px) rotate(-45deg);
    }
  }
</style>

<script>
  // ===== Логика бургер-меню =====
  document.addEventListener('DOMContentLoaded', () => {
    const burgerBtn = document.getElementById('burgerBtn');

    if (burgerBtn) {
      burgerBtn.addEventListener('click', () => {
        const isOpen = burgerBtn.classList.toggle('is-active');
        burgerBtn.setAttribute('aria-expanded', isOpen);

        if (isOpen) {
          window.openMobileMenu?.();
        } else {
          window.closeMobileMenu?.();
        }
      });
    }
  });
</script>