---
import '@fontsource/open-sans/300.css';
import '@fontsource/open-sans/400.css';
import '@fontsource/open-sans/600.css';
import '@fontsource/open-sans/700.css';
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import '../styles/global.css'
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "site2u.by",
  "url": "https://site2u.by",
  "telephone": "+375296195265",
  "email": "hello@site2u.by",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "пр. Независимости, д. 68-2, к.108",
    "addressLocality": "Минск",
    "addressCountry": "BY"
  }
};

interface Props {
  title: string;
  description: string;
  serviceSchema?: object;
  transparent?: boolean
}

const {title, description, serviceSchema, transparent = false} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL('/og-image.jpg', Astro.site);
---
<html lang="ru">
<head>
  <meta charset="UTF-8"/>
  <style is:global>
    .js-loading .hero__subtitle,
    .js-loading .hero__cta,
    .js-loading .hero__arrow {
      opacity: 0 !important;
    }
    .js-loading .services,
    .js-loading .about-teaser,
    .js-loading .advantages,
    .js-loading .process,
    .js-loading .configurator,
    .js-loading .cta {
      opacity: 0 !important;
      transform: translateY(35px) !important;
    }
  </style>
  <script is:inline>
    document.documentElement.classList.add('js-loading');
  </script>
  <meta name="viewport" content="width=device-width"/>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
  <link rel="icon" href="/favicon.ico"/>
  <meta name="generator" content={Astro.generator}/>
  <title>{title}</title>
  <meta name="description" content={description}/>
  <link rel="canonical" href={canonicalURL}/>
  <meta property="og:title" content={title}/>
  <meta property="og:description" content={description}/>
  <meta property="og:url" content={canonicalURL}/>
  <meta property="og:image" content={ogImageURL}/>
  <meta property="og:type" content="website"/>
  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)}/>
  {serviceSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  )}
  <script defer src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <link rel="stylesheet" href="/animations.css"/>
  <script defer src="/animations.js"></script>
  <script is:inline>
    function loadAnalytics() {
      // Google Analytics
      const gaScript = document.createElement('script');
      gaScript.async = true;
      gaScript.src = 'https://www.googletagmanager.com/gtag/js?id=G-9EL42XVXEB';
      document.head.appendChild(gaScript);
      gaScript.onload = function () {
        window.dataLayer = window.dataLayer || [];

        function gtag() {
          dataLayer.push(arguments);
        }

        window.gtag = gtag;
        gtag('js', new Date());
        gtag('config', 'G-9EL42XVXEB');
      };

      // Яндекс.Метрика
      (function (m, e, t, r, i, k, a) {
        m[i] = m[i] || function () {
          (m[i].a = m[i].a || []).push(arguments)
        };
        m[i].l = 1 * new Date();
        k = e.createElement(t), a = e.getElementsByTagName(t)[0], k.async = 1, k.src = r, a.parentNode.insertBefore(k, a)
      })(window, document, 'script', 'https://mc.yandex.ru/metrika/tag.js?id=110113534', 'ym');
      ym(110113534, 'init', {
        ssr: true,
        webvisor: true,
        clickmap: true,
        accurateTrackBounce: true,
        trackLinks: true
      });
    }

    if ('requestIdleCallback' in window) {
      requestIdleCallback(loadAnalytics);
    } else {
      setTimeout(loadAnalytics, 2000);
    }
  </script>
  <noscript>
    <div><img src="https://mc.yandex.ru/watch/110113534" style="position:absolute;left:-9999px;" alt=""/></div>
  </noscript>

  <script is:inline>
    document.addEventListener('click', function (e) {
      const target = e.target.closest('[data-track]');
      if (!target) return;

      const eventName = target.dataset.track;

      if (typeof gtag !== 'undefined') {
        gtag('event', eventName, {
          event_category: 'click',
          event_label: target.textContent.trim()
        });
      }

      if (typeof ym !== 'undefined') {
        ym(110113534, 'reachGoal', eventName);
      }
    });
  </script>
</head>
<body>
<Header transparent={transparent}/>
<main>
  <slot/>
</main>
<Footer/>


</body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  main {
    flex: 1;
  }
</style>